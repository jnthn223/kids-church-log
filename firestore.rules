rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function memberPath(ministryId, uid) { return /databases/$(database)/documents/ministries/$(ministryId)/members/$(uid); }
    function member(ministryId) { return get(memberPath(ministryId, request.auth.uid)).data; }
    function active(ministryId) { return signedIn() && request.auth.token.email_verified == true && exists(memberPath(ministryId, request.auth.uid)) && member(ministryId).status == 'ACTIVE' && member(ministryId).expiresAt is timestamp && member(ministryId).expiresAt > request.time; }
    function hasRole(ministryId, role) { return active(ministryId) && role in member(ministryId).roles; }
    function lead(ministryId) { return hasRole(ministryId, 'MINISTRY_LEAD'); }
    function adminVolunteer(ministryId) { return hasRole(ministryId, 'ADMIN_VOLUNTEER'); }
    function kidsVolunteer(ministryId) { return hasRole(ministryId, 'KIDS_CHURCH_VOLUNTEER'); }
    function team(ministryId) { return lead(ministryId) || adminVolunteer(ministryId) || kidsVolunteer(ministryId); }
    function validRoles(roles) { return roles is list && roles.size() >= 1 && roles.size() <= 3 && roles.hasOnly(['MINISTRY_LEAD', 'ADMIN_VOLUNTEER', 'KIDS_CHURCH_VOLUNTEER']); }
    function validExpiry(data) { return data.expiresAt is timestamp && data.expiresAt > request.time && (('MINISTRY_LEAD' in data.roles && data.expiresAt <= request.time + duration.value(180, 'd')) || (!('MINISTRY_LEAD' in data.roles) && data.expiresAt <= request.time + duration.value(365, 'd'))); }
    function validInactiveRoles(roles) { return roles is list && roles.size() <= 3 && roles.hasOnly(['MINISTRY_LEAD', 'ADMIN_VOLUNTEER', 'KIDS_CHURCH_VOLUNTEER']); }
    function validMember(data, uid) { return data.userId == uid && data.status in ['ACTIVE', 'SUSPENDED', 'REVOKED'] && ((data.status == 'ACTIVE' && validRoles(data.roles) && validExpiry(data)) || (data.status != 'ACTIVE' && validInactiveRoles(data.roles))); }
    function governanceAfter(ministryId) { return getAfter(/databases/$(database)/documents/ministries/$(ministryId)/settings/accessGovernance).data; }
    function leadRosterMatches(ministryId, uid, roles) { return (('MINISTRY_LEAD' in roles) == (uid in governanceAfter(ministryId).assignedMinistryLeadIds)) && governanceAfter(ministryId).assignedMinistryLeadIds.size() > 0; }
    function openSession(ministryId, sessionId) { return getAfter(/databases/$(database)/documents/ministries/$(ministryId)/serviceSessions/$(sessionId)).data.status == 'OPEN'; }
    function selectedPlacement(ministryId) { return getAfter(/databases/$(database)/documents/ministries/$(ministryId)/serviceSessions/$(request.resource.data.sessionId)/roomAssignments/$(request.resource.data.groupId)).data; }
    function checkedInChild(ministryId) { return get(/databases/$(database)/documents/ministries/$(ministryId)/children/$(request.resource.data.childId)).data; }
    function checkedInHousehold(ministryId) { return get(/databases/$(database)/documents/ministries/$(ministryId)/households/$(request.resource.data.householdId)).data; }
    function validVolunteerCheckIn(ministryId, attendanceId) { return request.resource.data.keys().hasAll(['childId','childNameSnapshot','householdId','householdNameSnapshot','sessionId','scheduleId','scheduleNameSnapshot','localServiceDate','groupId','groupNameSnapshot','roomId','roomNameSnapshot','registeredGroupId','placementOverridden','placementOverrideReason','status','checkInAt','checkInBy','checkInMethod']) && attendanceId == request.resource.data.sessionId + '_' + request.resource.data.childId && request.resource.data.status == 'CHECKED_IN' && request.resource.data.checkInBy == request.auth.uid && request.resource.data.checkInAt == request.time && request.resource.data.checkInMethod in ['QR','MANUAL','NFC'] && request.resource.data.childNameSnapshot is string && request.resource.data.householdNameSnapshot is string && request.resource.data.groupId is string && request.resource.data.groupNameSnapshot is string && request.resource.data.roomId is string && request.resource.data.roomNameSnapshot is string && request.resource.data.registeredGroupId is string && request.resource.data.placementOverridden is bool && request.resource.data.placementOverrideReason is string && request.resource.data.placementOverrideReason.size() <= 120 && (!request.resource.data.placementOverridden || request.resource.data.placementOverrideReason.size() >= 3) && openSession(ministryId, request.resource.data.sessionId) && checkedInHousehold(ministryId).active == true && ((checkedInHousehold(ministryId).childIds is list && request.resource.data.childId in checkedInHousehold(ministryId).childIds) || checkedInChild(ministryId).get('householdId', '') == request.resource.data.householdId) && checkedInChild(ministryId).active == true && selectedPlacement(ministryId).active == true && selectedPlacement(ministryId).roomId == request.resource.data.roomId; }
    function validVolunteerCheckOut(ministryId) { return resource.data.status == 'CHECKED_IN' && request.resource.data.status == 'CHECKED_OUT' && openSession(ministryId, resource.data.sessionId) && request.resource.data.checkOutBy == request.auth.uid && request.resource.data.checkOutAt == request.time && request.resource.data.checkOutMethod in ['QR','MANUAL','NFC'] && request.resource.data.releasedToGuardianId is string && request.resource.data.releasedToName is string && request.resource.data.releasedToGuardianId in get(/databases/$(database)/documents/ministries/$(ministryId)/children/$(resource.data.childId)).data.authorizedGuardianIds && get(/databases/$(database)/documents/ministries/$(ministryId)/guardians/$(request.resource.data.releasedToGuardianId)).data.active == true && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','checkOutAt','checkOutBy','checkOutMethod','releasedToGuardianId','releasedToName','checkoutNote']); }
    function validVolunteerSessionCreate() { return request.resource.data.keys().hasAll(['localServiceDate','scheduleId','scheduleName','sessionKind','status','openedAt','openedBy','revision','createdAt','createdBy','updatedAt','updatedBy']) && request.resource.data.localServiceDate is string && request.resource.data.scheduleId is string && request.resource.data.scheduleName is string && request.resource.data.sessionKind in ['SCHEDULED','ON_DEMAND'] && request.resource.data.status == 'OPEN' && request.resource.data.openedAt == request.time && request.resource.data.openedBy == request.auth.uid && request.resource.data.revision == 0 && request.resource.data.createdBy == request.auth.uid && request.resource.data.updatedBy == request.auth.uid; }
    function validVolunteerSessionMappingRevision() { return resource.data.status == 'OPEN' && request.resource.data.status == 'OPEN' && request.resource.data.revision == resource.data.revision + 1 && request.resource.data.roomMappingUpdatedBy == request.auth.uid && request.resource.data.updatedBy == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['revision','roomMappingUpdatedAt','roomMappingUpdatedBy','updatedAt','updatedBy']); }
    function validVolunteerSessionClose() { return resource.data.status == 'OPEN' && request.resource.data.status == 'CLOSED' && request.resource.data.closedAt == request.time && request.resource.data.closedBy == request.auth.uid && request.resource.data.updatedAt == request.time && request.resource.data.updatedBy == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','closedAt','closedBy','updatedAt','updatedBy']); }
    function validVolunteerRoomMapping(ministryId, sessionId, assignmentId) { return openSession(ministryId, sessionId) && assignmentId == request.resource.data.groupId && request.resource.data.groupId is string && request.resource.data.groupName is string && request.resource.data.roomId is string && request.resource.data.roomName is string && request.resource.data.active is bool && request.resource.data.updatedBy == request.auth.uid && (request.resource.data.active == false || (get(/databases/$(database)/documents/ministries/$(ministryId)/ministryGroups/$(request.resource.data.groupId)).data.active == true && get(/databases/$(database)/documents/ministries/$(ministryId)/rooms/$(request.resource.data.roomId)).data.active == true)); }
    function validVolunteerServingArea(ministryId, sessionId) { return request.resource.data.groupId is string && request.resource.data.roomId is string && request.resource.data.servingAreaLabel is string && request.resource.data.servingAreaLabel.size() >= 3 && request.resource.data.servingAreaLabel.size() <= 160 && ((request.resource.data.groupId == '' && request.resource.data.roomId == '' && request.resource.data.servingAreaLabel == 'Check-in / service-wide') || (request.resource.data.groupId.size() > 0 && getAfter(/databases/$(database)/documents/ministries/$(ministryId)/serviceSessions/$(sessionId)/roomAssignments/$(request.resource.data.groupId)).data.active == true && getAfter(/databases/$(database)/documents/ministries/$(ministryId)/serviceSessions/$(sessionId)/roomAssignments/$(request.resource.data.groupId)).data.roomId == request.resource.data.roomId)); }
    function validVolunteerAssignmentCreate(ministryId, sessionId, assignmentId) { return openSession(ministryId, sessionId) && assignmentId == request.auth.uid && request.resource.data.keys().hasOnly(['memberUid','displayName','assignmentRole','groupId','roomId','servingAreaLabel','active','joinedAt','joinedBy']) && request.resource.data.keys().hasAll(['memberUid','displayName','assignmentRole','groupId','roomId','servingAreaLabel','active','joinedAt','joinedBy']) && request.resource.data.memberUid == request.auth.uid && request.resource.data.displayName is string && request.resource.data.displayName.size() >= 2 && request.resource.data.displayName.size() <= 100 && request.resource.data.assignmentRole in ['Service opener','Session volunteer'] && request.resource.data.active == true && request.resource.data.joinedAt == request.time && request.resource.data.joinedBy == request.auth.uid && validVolunteerServingArea(ministryId, sessionId); }
    function validVolunteerAssignmentUpdate(ministryId, sessionId, assignmentId) { return openSession(ministryId, sessionId) && assignmentId == request.auth.uid && resource.data.memberUid == request.auth.uid && request.resource.data.memberUid == resource.data.memberUid && request.resource.data.displayName == resource.data.displayName && request.resource.data.assignmentRole == resource.data.assignmentRole && request.resource.data.active == resource.data.active && request.resource.data.joinedAt == resource.data.joinedAt && request.resource.data.joinedBy == resource.data.joinedBy && request.resource.data.assignmentUpdatedAt == request.time && request.resource.data.assignmentUpdatedBy == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['groupId','roomId','servingAreaLabel','assignmentUpdatedAt','assignmentUpdatedBy']) && validVolunteerServingArea(ministryId, sessionId); }
    function validVolunteerRoomMove(ministryId) { return resource.data.status == 'CHECKED_IN' && request.resource.data.status == 'CHECKED_IN' && openSession(ministryId, resource.data.sessionId) && request.resource.data.roomChangedBy == request.auth.uid && request.resource.data.roomChangedAt == request.time && request.resource.data.roomChangeReason is string && request.resource.data.roomChangeReason.size() >= 5 && get(/databases/$(database)/documents/ministries/$(ministryId)/serviceSessions/$(resource.data.sessionId)/roomAssignments/$(resource.data.groupId)).data.roomId == request.resource.data.roomId && get(/databases/$(database)/documents/ministries/$(ministryId)/serviceSessions/$(resource.data.sessionId)/roomAssignments/$(resource.data.groupId)).data.roomName == request.resource.data.roomNameSnapshot && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['roomId','roomNameSnapshot','roomChangedAt','roomChangedBy','roomChangeReason']); }

    match /users/{uid} {
      allow get: if signedIn() && request.auth.uid == uid;
      allow create: if signedIn() && request.auth.uid == uid && request.resource.data.keys().hasOnly(['displayName','normalizedEmail','photoUrl','defaultMinistryId','updatedAt']);
      allow update: if signedIn() && request.auth.uid == uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName','normalizedEmail','photoUrl','defaultMinistryId','updatedAt']);
      allow list, delete: if false;
    }

    match /ministries/{ministryId} {
      allow read: if active(ministryId);
      allow create, update: if lead(ministryId) && request.resource.data.updatedBy == request.auth.uid;
      allow delete: if false;

      match /accessRequests/{uid} {
        allow get: if signedIn() && request.auth.uid == uid || lead(ministryId);
        allow list: if lead(ministryId);
        allow create: if signedIn() && request.auth.uid == uid && request.resource.data.uid == request.auth.uid && request.resource.data.email == request.auth.token.email && request.resource.data.displayName is string && request.resource.data.displayName.size() >= 2 && request.resource.data.displayName.size() <= 100 && request.resource.data.status == 'PENDING' && request.resource.data.keys().hasOnly(['uid','email','displayName','providerIds','requestedApplication','ministryResponsibility','requestReason','status','requestedAt']) && (!('ministryResponsibility' in request.resource.data) || (request.resource.data.ministryResponsibility is string && request.resource.data.ministryResponsibility.size() >= 2 && request.resource.data.ministryResponsibility.size() <= 120)) && (!('requestReason' in request.resource.data) || (request.resource.data.requestReason is string && request.resource.data.requestReason.size() >= 10 && request.resource.data.requestReason.size() <= 500));
        allow update: if lead(ministryId) && request.resource.data.uid == resource.data.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','reviewedAt','reviewedBy']);
        allow delete: if false;
      }

      match /members/{uid} {
        allow get: if signedIn() && request.auth.uid == uid || lead(ministryId);
        allow list: if lead(ministryId);
        allow create: if lead(ministryId) && request.auth.uid != uid && validMember(request.resource.data, uid) && leadRosterMatches(ministryId, uid, request.resource.data.roles);
        allow update: if lead(ministryId) && request.auth.uid != uid && validMember(request.resource.data, uid) && request.resource.data.userId == resource.data.userId && (request.resource.data.status != 'ACTIVE' || leadRosterMatches(ministryId, uid, request.resource.data.roles));
        allow delete: if false;
      }

      match /settings/accessGovernance {
        allow read: if lead(ministryId);
        allow create, update: if lead(ministryId) && request.resource.data.updatedBy == request.auth.uid && request.resource.data.assignedMinistryLeadIds is list && request.resource.data.assignedMinistryLeadIds.size() > 0 && request.resource.data.minimumActiveLeadTarget >= 2 && request.resource.data.leadReviewIntervalDays >= 90 && request.resource.data.leadReviewIntervalDays <= 180;
        allow delete: if false;
      }
      match /settings/{settingId} { allow read: if active(ministryId); allow create, update: if lead(ministryId) && request.resource.data.updatedBy == request.auth.uid; allow delete: if false; }

      match /households/{id} {
        allow read: if lead(ministryId) || adminVolunteer(ministryId) || kidsVolunteer(ministryId);
        allow create: if (lead(ministryId) || adminVolunteer(ministryId)) && request.resource.data.active == true && request.resource.data.passStatus == 'ACTIVE' && request.resource.data.createdBy == request.auth.uid && request.resource.data.updatedBy == request.auth.uid;
        allow update: if lead(ministryId) || (adminVolunteer(ministryId) && request.resource.data.active == resource.data.active && request.resource.data.passStatus == resource.data.passStatus && request.resource.data.createdBy == resource.data.createdBy && request.resource.data.updatedBy == request.auth.uid);
        allow delete: if false;
      }
      match /guardians/{id} {
        allow read: if lead(ministryId) || adminVolunteer(ministryId) || kidsVolunteer(ministryId);
        allow create: if (lead(ministryId) || adminVolunteer(ministryId)) && request.resource.data.active == true && request.resource.data.createdBy == request.auth.uid && request.resource.data.updatedBy == request.auth.uid;
        allow update: if lead(ministryId) || (adminVolunteer(ministryId) && request.resource.data.active == resource.data.active && request.resource.data.createdBy == resource.data.createdBy && request.resource.data.updatedBy == request.auth.uid);
        allow delete: if false;
      }
      match /children/{id} {
        allow read: if lead(ministryId) || adminVolunteer(ministryId) || kidsVolunteer(ministryId);
        allow create: if (lead(ministryId) || adminVolunteer(ministryId)) && request.resource.data.active == true && request.resource.data.authorizedGuardianIds is list && request.resource.data.authorizedGuardianIds.size() >= 1 && request.resource.data.createdBy == request.auth.uid && request.resource.data.updatedBy == request.auth.uid;
        allow update: if lead(ministryId) || (adminVolunteer(ministryId) && request.resource.data.active == resource.data.active && request.resource.data.authorizedGuardianIds is list && request.resource.data.authorizedGuardianIds.size() >= 1 && request.resource.data.createdBy == resource.data.createdBy && request.resource.data.updatedBy == request.auth.uid);
        allow delete: if false;
      }
      match /familyPassSecrets/{id} {
        allow read: if lead(ministryId) || adminVolunteer(ministryId);
        allow create: if (lead(ministryId) || adminVolunteer(ministryId)) && request.resource.data.status == 'ACTIVE' && request.resource.data.createdBy == request.auth.uid && request.resource.data.updatedBy == request.auth.uid;
        allow update: if lead(ministryId) || (adminVolunteer(ministryId) && resource.data.status == 'ACTIVE' && request.resource.data.status == 'ACTIVE' && request.resource.data.householdId == resource.data.householdId && request.resource.data.createdBy == resource.data.createdBy && request.resource.data.updatedBy == request.auth.uid);
        allow delete: if false;
      }
      match /familyPasses/{tokenHash} {
        allow get: if team(ministryId); allow list: if lead(ministryId) || adminVolunteer(ministryId);
        allow create: if (lead(ministryId) || adminVolunteer(ministryId)) && request.resource.data.status == 'ACTIVE' && request.resource.data.issuedBy == request.auth.uid;
        allow update: if lead(ministryId) || (adminVolunteer(ministryId) && resource.data.status == 'ACTIVE' && request.resource.data.status == 'REPLACED' && request.resource.data.householdId == resource.data.householdId && request.resource.data.replacedBy == request.auth.uid && request.resource.data.replacementHash is string);
        allow delete: if false;
      }

      match /ministryGroups/{id} { allow read: if active(ministryId); allow create, update: if lead(ministryId); allow delete: if false; }
      match /rooms/{id} { allow read: if active(ministryId); allow create, update: if lead(ministryId); allow delete: if false; }
      match /serviceSchedules/{id} { allow read: if active(ministryId); allow create, update: if lead(ministryId); allow delete: if false; }
      match /serviceSessions/{id} {
        allow read: if active(ministryId);
        allow create: if lead(ministryId) || (kidsVolunteer(ministryId) && validVolunteerSessionCreate());
        allow update: if lead(ministryId) || (kidsVolunteer(ministryId) && (validVolunteerSessionMappingRevision() || validVolunteerSessionClose()));
        allow delete: if false;
        match /roomAssignments/{assignmentId} {
          allow read: if active(ministryId);
          allow create, update: if lead(ministryId) || (kidsVolunteer(ministryId) && validVolunteerRoomMapping(ministryId, id, assignmentId));
          allow delete: if false;
        }
        match /volunteerAssignments/{assignmentId} { allow read: if active(ministryId); allow create: if lead(ministryId) || (kidsVolunteer(ministryId) && validVolunteerAssignmentCreate(ministryId, id, assignmentId)); allow update: if lead(ministryId) || (kidsVolunteer(ministryId) && validVolunteerAssignmentUpdate(ministryId, id, assignmentId)); allow delete: if false; }
      }
      match /attendance/{id} {
        allow read: if lead(ministryId) || kidsVolunteer(ministryId);
        allow create: if lead(ministryId) || (kidsVolunteer(ministryId) && validVolunteerCheckIn(ministryId, id));
        allow update: if lead(ministryId) || (kidsVolunteer(ministryId) && (validVolunteerCheckOut(ministryId) || validVolunteerRoomMove(ministryId)));
        allow delete: if false;
      }
      match /auditLogs/{id} { allow read: if lead(ministryId); allow create: if active(ministryId) && request.resource.data.actorUid == request.auth.uid && request.resource.data.applicationSource in ['MINISTRY_LEAD','ADMIN_VOLUNTEER','KIDS_CHURCH_VOLUNTEER']; allow update, delete: if false; }
    }
  }
}
